# LLM Configuration
# Set LLM_ENABLED=true to enable LLM-powered solution generation
# When disabled, the system uses preset rules only

APP_LLM_ENABLED=false

# Provider: openai, deepseek, ollama, vllm, localai
APP_LLM_PROVIDER=openai

# API Key (not needed for local models like Ollama)
APP_LLM_API_KEY=

# API Base URL
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama: http://localhost:11434/v1
# vLLM: http://localhost:8000/v1
# LocalAI: http://localhost:8080/v1
APP_LLM_API_BASE=https://api.openai.com/v1

# Model name
# OpenAI: gpt-4o-mini, gpt-4o
# DeepSeek: deepseek-chat, deepseek-reasoner
# Ollama: qwen2.5:7b, llama3.1:8b, deepseek-r1:7b
# vLLM: depends on loaded model
APP_LLM_MODEL=gpt-4o-mini

# Generation parameters
APP_LLM_TEMPERATURE=0.3
APP_LLM_MAX_TOKENS=4096
APP_LLM_TIMEOUT=60

# Fallback: when LLM fails, fall back to preset rules
APP_LLM_FALLBACK_ENABLED=true
